{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the system (Root or Sub-Admin)",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["root", "sub-admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global settings for the Ayaland CMS",
      "type": "object",
      "properties": {
        "brandName": { "type": "string" },
        "hotline": { "type": "string" },
        "zalo": { "type": "string" },
        "title": { "type": "string" },
        "favicon": { "type": "string" },
        "logo": { "type": "string" },
        "heroTitle": { "type": "object", "additionalProperties": { "type": "string" } },
        "heroSubtitle": { "type": "object", "additionalProperties": { "type": "string" } },
        "heroImages": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["brandName"]
    },
    "Language": {
      "title": "Language",
      "description": "A supported language in the system",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "isDefault": { "type": "boolean" }
      },
      "required": ["code", "name", "isDefault"]
    },
    "Project": {
      "title": "Project",
      "description": "A real estate project",
      "type": "object",
      "properties": {
        "title": { "type": "object", "additionalProperties": { "type": "string" } },
        "description": { "type": "object", "additionalProperties": { "type": "string" } },
        "location": { "type": "object", "additionalProperties": { "type": "string" } },
        "price": { "type": "number" },
        "area": { "type": "number" },
        "type": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "price", "area", "type", "createdAt", "createdBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Global settings (e.g., 'general')"
    },
    "/languages/{langId}": {
      "schema": { "$ref": "#/entities/Language" },
      "description": "Supported languages"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Real estate projects"
    }
  }
}
